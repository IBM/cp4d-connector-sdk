{
  "$connector_name": "SpaceX API Connector",
  "$connector_label": "SpaceX API",
  "$connector_description": "Connector for SpaceX public REST API - provides access to rockets, launches, capsules, crew, and more",
  "$hostname": "https://api.spacexdata.com",
  "$authentication": "none",
  "$tables": {
    "COMPANY": {
      "$path": ["/v4/company"],
      "id": "VARCHAR,$key",
      "name": "VARCHAR",
      "founder": "VARCHAR",
      "founded": "INTEGER",
      "employees": "INTEGER",
      "vehicles": "INTEGER",
      "launch_sites": "INTEGER",
      "test_sites": "INTEGER",
      "ceo": "VARCHAR",
      "cto": "VARCHAR",
      "coo": "VARCHAR",
      "cto_propulsion": "VARCHAR",
      "valuation": "BIGINT",
      "summary": "VARCHAR",
      "headquarters[]": {
        "address": "VARCHAR",
        "city": "VARCHAR",
        "state": "VARCHAR"
      },
      "links": "VARCHAR"
    },
    "ROCKETS": {
      "$path": ["/v4/rockets"],
      "id": "VARCHAR,$key",
      "name": "VARCHAR",
      "type": "VARCHAR",
      "active": "BOOLEAN",
      "stages": "INTEGER",
      "boosters": "INTEGER",
      "cost_per_launch": "BIGINT",
      "success_rate_pct": "INTEGER",
      "first_flight": "DATE",
      "country": "VARCHAR",
      "company": "VARCHAR",
      "wikipedia": "VARCHAR",
      "description": "VARCHAR",
      "height": "VARCHAR",
      "diameter": "VARCHAR",
      "mass": "VARCHAR",
      "first_stage": "VARCHAR",
      "second_stage": "VARCHAR",
      "engines": "VARCHAR",
      "landing_legs": "VARCHAR",
      "payload_weights": "VARCHAR",
      "flickr_images": "VARCHAR"
    },
    "CAPSULES": {
      "$path": ["/v4/capsules"],
      "id": "VARCHAR,$key",
      "serial": "VARCHAR",
      "status": "VARCHAR",
      "type": "VARCHAR",
      "reuse_count": "INTEGER",
      "water_landings": "INTEGER",
      "land_landings": "INTEGER",
      "last_update": "VARCHAR",
      "launches": "VARCHAR"
    },
    "CREW": {
      "$path": ["/v4/crew"],
      "id": "VARCHAR,$key",
      "name": "VARCHAR",
      "agency": "VARCHAR",
      "image": "VARCHAR",
      "wikipedia": "VARCHAR",
      "status": "VARCHAR",
      "launches": "VARCHAR"
    },
    "CORES": {
      "$path": ["/v4/cores"],
      "id": "VARCHAR,$key",
      "serial": "VARCHAR",
      "block": "INTEGER",
      "status": "VARCHAR",
      "reuse_count": "INTEGER",
      "rtls_attempts": "INTEGER",
      "rtls_landings": "INTEGER",
      "asds_attempts": "INTEGER",
      "asds_landings": "INTEGER",
      "last_update": "VARCHAR",
      "launches": "VARCHAR"
    },
    "DRAGONS": {
      "$path": ["/v4/dragons"],
      "id": "VARCHAR,$key",
      "name": "VARCHAR",
      "type": "VARCHAR",
      "active": "BOOLEAN",
      "crew_capacity": "INTEGER",
      "sidewall_angle_deg": "INTEGER",
      "orbit_duration_yr": "INTEGER",
      "dry_mass_kg": "INTEGER",
      "dry_mass_lb": "INTEGER",
      "first_flight": "DATE",
      "wikipedia": "VARCHAR",
      "description": "VARCHAR",
      "heat_shield": "VARCHAR",
      "launch_payload_mass": "VARCHAR",
      "launch_payload_vol": "VARCHAR",
      "return_payload_mass": "VARCHAR",
      "return_payload_vol": "VARCHAR",
      "pressurized_capsule": "VARCHAR",
      "trunk": "VARCHAR",
      "height_w_trunk": "VARCHAR",
      "diameter": "VARCHAR",
      "thrusters": "VARCHAR",
      "flickr_images": "VARCHAR"
    },
    "LAUNCHES": {
      "$path": ["/v4/launches"],
      "id": "VARCHAR,$key",
      "flight_number": "INTEGER",
      "name": "VARCHAR",
      "date_utc": "TIMESTAMP",
      "date_unix": "BIGINT",
      "date_local": "VARCHAR",
      "date_precision": "VARCHAR",
      "upcoming": "BOOLEAN",
      "rocket": "VARCHAR",
      "success": "BOOLEAN",
      "details": "VARCHAR",
      "launchpad": "VARCHAR",
      "auto_update": "BOOLEAN",
      "tbd": "BOOLEAN",
      "launch_library_id": "VARCHAR",
      "static_fire_date_utc": "TIMESTAMP",
      "static_fire_date_unix": "BIGINT",
      "net": "BOOLEAN",
      "window": "INTEGER",
      "fairings": "VARCHAR",
      "links": "VARCHAR",
      "failures": "VARCHAR",
      "crew": "VARCHAR",
      "ships": "VARCHAR",
      "capsules": "VARCHAR",
      "payloads": "VARCHAR",
      "cores[]": "VARCHAR"
    },
    "LAUNCHPADS": {
      "$path": ["/v4/launchpads"],
      "id": "VARCHAR,$key",
      "name": "VARCHAR",
      "full_name": "VARCHAR",
      "locality": "VARCHAR",
      "region": "VARCHAR",
      "latitude": "DOUBLE",
      "longitude": "DOUBLE",
      "launch_attempts": "INTEGER",
      "launch_successes": "INTEGER",
      "timezone": "VARCHAR",
      "status": "VARCHAR",
      "details": "VARCHAR",
      "rockets": "VARCHAR",
      "launches": "VARCHAR",
      "images": "VARCHAR"
    },
    "LANDPADS": {
      "$path": ["/v4/landpads"],
      "id": "VARCHAR,$key",
      "name": "VARCHAR",
      "full_name": "VARCHAR",
      "status": "VARCHAR",
      "type": "VARCHAR",
      "locality": "VARCHAR",
      "region": "VARCHAR",
      "latitude": "DOUBLE",
      "longitude": "DOUBLE",
      "landing_attempts": "INTEGER",
      "landing_successes": "INTEGER",
      "wikipedia": "VARCHAR",
      "details": "VARCHAR",
      "launches": "VARCHAR",
      "images": "VARCHAR"
    },
    "PAYLOADS": {
      "$path": ["/v4/payloads"],
      "id": "VARCHAR,$key",
      "name": "VARCHAR",
      "type": "VARCHAR",
      "reused": "BOOLEAN",
      "launch": "VARCHAR",
      "orbit": "VARCHAR",
      "reference_system": "VARCHAR",
      "regime": "VARCHAR",
      "longitude": "DOUBLE",
      "semi_major_axis_km": "DOUBLE",
      "eccentricity": "DOUBLE",
      "periapsis_km": "DOUBLE",
      "apoapsis_km": "DOUBLE",
      "inclination_deg": "DOUBLE",
      "period_min": "DOUBLE",
      "lifespan_years": "INTEGER",
      "epoch": "TIMESTAMP",
      "mean_motion": "DOUBLE",
      "raan": "DOUBLE",
      "arg_of_pericenter": "DOUBLE",
      "mean_anomaly": "DOUBLE",
      "mass_kg": "DOUBLE",
      "mass_lbs": "DOUBLE",
      "dragon": "VARCHAR",
      "customers": "VARCHAR",
      "norad_ids": "VARCHAR",
      "nationalities": "VARCHAR",
      "manufacturers": "VARCHAR"
    },
    "SHIPS": {
      "$path": ["/v4/ships"],
      "id": "VARCHAR,$key",
      "name": "VARCHAR",
      "legacy_id": "VARCHAR",
      "model": "VARCHAR",
      "type": "VARCHAR",
      "active": "BOOLEAN",
      "imo": "INTEGER",
      "mmsi": "INTEGER",
      "abs": "INTEGER",
      "class": "INTEGER",
      "mass_kg": "INTEGER",
      "mass_lbs": "INTEGER",
      "year_built": "INTEGER",
      "home_port": "VARCHAR",
      "status": "VARCHAR",
      "speed_kn": "DOUBLE",
      "course_deg": "DOUBLE",
      "latitude": "DOUBLE",
      "longitude": "DOUBLE",
      "last_ais_update": "TIMESTAMP",
      "link": "VARCHAR",
      "image": "VARCHAR",
      "roles": "VARCHAR",
      "launches": "VARCHAR"
    },
    "STARLINK": {
      "$path": ["/v4/starlink"],
      "id": "VARCHAR,$key",
      "version": "VARCHAR",
      "launch": "VARCHAR",
      "longitude": "DOUBLE",
      "latitude": "DOUBLE",
      "height_km": "DOUBLE",
      "velocity_kms": "DOUBLE",
      "spaceTrack": "VARCHAR"
    }
  }
}