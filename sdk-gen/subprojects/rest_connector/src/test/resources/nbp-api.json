{
  "$connector_name": "NBP API Connector",
  "$connector_label": "NBP API",
  "$connector_description": "Connector for Polish National Bank (NBP) public REST API providing exchange rates and gold prices",
  "$hostname": "https://api.nbp.pl",
  "$authentication": "none",
  "$tables": {
    "EXCHANGE_RATES_TABLE_A": {
      "$path": ["/api/exchangerates/tables/A/last/50"],
      "ROWID": "VARCHAR,$key",
      "table": "VARCHAR",
      "no": "VARCHAR",
      "effectiveDate": "DATE",
      "rates[]": {
        "currency": "VARCHAR",
        "code": "VARCHAR",
        "mid": "DECIMAL"
      }
    },
    "EXCHANGE_RATES_TABLE_C": {
      "$path": ["/api/exchangerates/tables/C/last/50"],
      "ROWID": "VARCHAR,$key",
      "table": "VARCHAR",
      "no": "VARCHAR",
      "tradingDate": "DATE",
      "effectiveDate": "DATE",
      "rates[]": {
        "currency": "VARCHAR",
        "code": "VARCHAR",
        "bid": "DECIMAL",
        "ask": "DECIMAL"
      }
    },
    "GOLD_PRICES": {
      "$path": ["/api/cenyzlota/last/50"],
      "ROWID": "VARCHAR,$key",
      "data": "DATE",
      "cena": "DECIMAL"
    }
  }
}