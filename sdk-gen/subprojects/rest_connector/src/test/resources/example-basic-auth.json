{
  "$connector_name": "Example Basic Auth Connector",
  "$connector_label": "Example Basic Authentication",
  "$connector_description": "Example REST API connector using Basic (username/password) authentication",
  "$hostname": "https://api.example.com",
  "$authentication": "basic",
  "$tables": {
    "employees": {
      "$endpoint": "/api/employees",
      "$schema": {
        "employee_id": {
          "$type": "INTEGER",
          "$nullable": false
        },
        "first_name": {
          "$type": "VARCHAR",
          "$length": 100,
          "$nullable": false
        },
        "last_name": {
          "$type": "VARCHAR",
          "$length": 100,
          "$nullable": false
        },
        "email": {
          "$type": "VARCHAR",
          "$length": 255,
          "$nullable": false
        },
        "department": {
          "$type": "VARCHAR",
          "$length": 100,
          "$nullable": true
        },
        "hire_date": {
          "$type": "DATE",
          "$nullable": true
        },
        "salary": {
          "$type": "DECIMAL",
          "$precision": 10,
          "$scale": 2,
          "$nullable": true
        },
        "is_manager": {
          "$type": "BOOLEAN",
          "$nullable": false
        }
      }
    },
    "departments": {
      "$endpoint": "/api/departments",
      "$schema": {
        "department_id": {
          "$type": "INTEGER",
          "$nullable": false
        },
        "department_name": {
          "$type": "VARCHAR",
          "$length": 100,
          "$nullable": false
        },
        "location": {
          "$type": "VARCHAR",
          "$length": 200,
          "$nullable": true
        },
        "budget": {
          "$type": "DECIMAL",
          "$precision": 15,
          "$scale": 2,
          "$nullable": true
        },
        "manager_id": {
          "$type": "INTEGER",
          "$nullable": true
        },
        "created_date": {
          "$type": "TIMESTAMP",
          "$nullable": true
        }
      }
    }
  }
}