<jdbc_connector_workflow>
  <overview>
    This workflow guides you through creating a custom JDBC connector for any database
    using the IBM Watson Data Platform Connect SDK. The process involves creating a DSL
    configuration, generating connector code, customizing it, generating tests, and building
    the final connector.
  </overview>

  <prerequisites>
    <requirement>Java 11 or higher installed</requirement>
    <requirement>Gradle 7.x or higher</requirement>
    <requirement>Access to the target database for testing</requirement>
    <requirement>JDBC driver information for the target database</requirement>
    <requirement>Working directory must be sdk-gen/</requirement>
  </prerequisites>

  <workflow_phases>
    <phase number="1" name="information_gathering">
      <title>Gather Database Information</title>
      <description>
        Collect all necessary information about the target database before starting
        the connector creation process.
      </description>
      <required_information>
        <item>Database name (e.g., db2, mysql, postgresql, oracle)</item>
        <item>JDBC driver class name (e.g., com.ibm.db2.jcc.DB2Driver)</item>
        <item>JDBC URL template (e.g., jdbc:db2://{host}:{port}/{database})</item>
        <item>JDBC driver Maven coordinates (group:artifact:version)</item>
        <item>Default port number for the database</item>
        <item>Whether database supports schemas, catalogs, or both</item>
      </required_information>
      <actions>
        <action>Ask user for the database name they want to create a connector for</action>
        <action>Determine if user has JDBC driver information or needs help finding it</action>
        <action>Validate that we have all required information before proceeding</action>
      </actions>
    </phase>

    <phase number="2" name="dsl_creation">
      <title>Create DSL Configuration</title>
      <description>
        Create a database-specific DSL configuration file based on DSL-jdbc.json template.
        This file defines all connector properties, driver information, and customizations.
      </description>
      <steps>
        <step number="1">
          <action>Read the DSL-jdbc.json template file</action>
          <tool>read_file</tool>
          <file>DSL-jdbc.json</file>
        </step>
        <step number="2">
          <action>Create new DSL file named DSL-jdbc-{database}.json</action>
          <tool>write_to_file</tool>
          <naming_convention>DSL-jdbc-{database}.json (e.g., DSL-jdbc-db2.json)</naming_convention>
        </step>
        <step number="3">
          <action>Fill in connector metadata</action>
          <fields>
            <field>connector_name: jdbc_{database} (e.g., jdbc_db2)</field>
            <field>connector_label: {Database Name} (e.g., IBM Db2)</field>
            <field>connector_description: Brief description of the connector</field>
          </fields>
        </step>
        <step number="4">
          <action>Configure JDBC driver information</action>
          <fields>
            <field>driver_class_name: Fully qualified driver class</field>
            <field>jdbc_url: JDBC URL template with {placeholders}</field>
          </fields>
        </step>
        <step number="5">
          <action>Add driver dependencies</action>
          <location>implementation_notes.dependencies[0].driver_dependencies</location>
          <format>["group:artifact:version"]</format>
          <example>["com.ibm.db2:jcc:11.5.8.0"]</example>
        </step>
      </steps>
      <validation>
        <check>Verify connector_label is user-friendly and descriptive</check>
        <check>Ensure driver_class_name is correct for the database</check>
        <check>Confirm jdbc_url template uses correct syntax</check>
        <check>Validate driver_dependencies array is properly formatted</check>
      </validation>
    </phase>

    <phase number="3" name="label_confirmation">
      <title>Confirm Connector Label</title>
      <description>
        Ask the user to confirm the connector_label before proceeding, as this will
        be visible in the UI and should be user-friendly.
      </description>
      <actions>
        <action>Extract connector_label from the created DSL file</action>
        <action>Use ask_followup_question to confirm with user</action>
        <action>If user wants to change it, update the DSL file</action>
      </actions>
      <example_question>
        I've set the connector label to "{label}". This will be displayed in the
        Cloud Pak for Data UI. Is this label acceptable, or would you like to change it?
      </example_question>
    </phase>

    <phase number="4" name="code_generation">
      <title>Generate Connector Template Code</title>
      <description>
        Run the autoGenerateJavaJdbc Gradle task to generate the connector skeleton code
        from the DSL configuration.
      </description>
      <steps>
        <step number="1">
          <action>Change to sdk-gen directory if not already there</action>
          <command>cd sdk-gen</command>
        </step>
        <step number="2">
          <action>Run the autoGenerateJavaJdbc task</action>
          <command>./gradlew autoGenerateJavaJdbc -PdslFile=../DSL-jdbc-{database}.json</command>
          <note>The DSL file path is relative to sdk-gen directory</note>
        </step>
        <step number="3">
          <action>Wait for task completion and verify success</action>
          <success_indicators>
            <indicator>BUILD SUCCESSFUL message</indicator>
            <indicator>New directory created in subprojects/</indicator>
            <indicator>Java source files generated</indicator>
          </success_indicators>
        </step>
      </steps>
      <output>
        <location>sdk-gen/subprojects/jdbc_{database}/</location>
        <generated_files>
          <file>src/main/java/.../Connector.java</file>
          <file>src/main/java/.../ConnectorFactory.java</file>
          <file>src/main/java/.../DatasourceType.java</file>
          <file>src/main/java/.../FlightProducer.java</file>
          <file>src/main/java/.../SourceInteraction.java</file>
          <file>src/main/java/.../TargetInteraction.java</file>
          <file>src/main/resources/.../Labels.properties</file>
          <file>src/main/resources/.../Msgs.properties</file>
          <file>build.gradle</file>
        </generated_files>
      </output>
    </phase>

    <phase number="5" name="dsl_relocation">
      <title>Move DSL to Connector Directory</title>
      <description>
        Move the DSL configuration file to the generated connector's resources directory
        for use in subsequent customization steps.
      </description>
      <steps>
        <step number="1">
          <action>Identify the generated connector directory</action>
          <pattern>sdk-gen/subprojects/jdbc_{database}/</pattern>
        </step>
        <step number="2">
          <action>Create the target directory if it doesn't exist</action>
          <command>mkdir -p sdk-gen/subprojects/jdbc_{database}/src/dist/resources/payload/etc/</command>
        </step>
        <step number="3">
          <action>Copy DSL file to connector directory</action>
          <source>DSL-jdbc-{database}.json</source>
          <destination>sdk-gen/subprojects/jdbc_{database}/src/dist/resources/payload/etc/DSL-jdbc-{database}.json</destination>
          <tool>execute_command with cp or use read_file + write_to_file</tool>
        </step>
      </steps>
    </phase>

    <phase number="6" name="connector_customization">
      <title>Customize Connector Code</title>
      <description>
        Run the customizeJdbcConnector task to apply DSL configuration to the generated
        connector code, updating driver class names, connection URLs, and properties.
      </description>
      <steps>
        <step number="1">
          <action>Run customizeJdbcConnector task</action>
          <command>./gradlew customizeJdbcConnector -PdslFile=subprojects/jdbc_{database}/src/dist/resources/payload/etc/DSL-jdbc-{database}.json -PconnectorDir=subprojects/jdbc_{database}</command>
          <working_directory>sdk-gen/</working_directory>
        </step>
        <step number="2">
          <action>Verify customization success</action>
          <success_indicators>
            <indicator>✅ Updated DRIVER_CLASS_NAME message</indicator>
            <indicator>✅ Updated getConnectionURL() method message</indicator>
            <indicator>✅ Created CUSTOMIZATION_SUMMARY.md</indicator>
          </success_indicators>
        </step>
      </steps>
      <what_it_does>
        <update>Updates Connector.java with correct JDBC driver class name</update>
        <update>Modifies getConnectionURL() method to build correct JDBC URL</update>
        <update>Adds driver dependencies to build.gradle</update>
        <update>Updates DatasourceType.java with metadata</update>
        <update>Creates CUSTOMIZATION_SUMMARY.md documentation</update>
      </what_it_does>
    </phase>

    <phase number="7" name="test_generation">
      <title>Generate Test Suite</title>
      <description>
        Generate comprehensive property validation tests for the connector using the
        generateJdbcTests task.
      </description>
      <steps>
        <step number="1">
          <action>Run generateJdbcTests task</action>
          <command>./gradlew generateJdbcTests -PdslFile=subprojects/jdbc_{database}/src/dist/resources/payload/etc/DSL-jdbc-{database}.json -PconnectorDir=subprojects/jdbc_{database}</command>
          <working_directory>sdk-gen/</working_directory>
        </step>
        <step number="2">
          <action>Verify test file generation</action>
          <expected_file>sdk-gen/subprojects/jdbc_{database}/src/test/java/.../TestPropertyValidation.java</expected_file>
        </step>
      </steps>
      <generated_tests>
        <test>Basic connection property validation</test>
        <test>Missing required properties (negative tests)</test>
        <test>Source properties validation</test>
        <test>Target properties validation</test>
        <test>Filter properties validation</test>
        <test>Additional custom properties validation</test>
      </generated_tests>
    </phase>

    <phase number="8" name="code_formatting">
      <title>Apply Code Formatting</title>
      <description>
        Run spotlessApply to format all generated and customized code according to
        project standards.
      </description>
      <steps>
        <step number="1">
          <action>Run spotlessApply task</action>
          <command>./gradlew spotlessApply</command>
          <working_directory>sdk-gen/</working_directory>
        </step>
      </steps>
    </phase>

    <phase number="9" name="build">
      <title>Build Connector</title>
      <description>
        Build the connector without running tests to verify compilation and packaging.
      </description>
      <steps>
        <step number="1">
          <action>Run build task excluding tests</action>
          <command>./gradlew build -x test</command>
          <working_directory>sdk-gen/</working_directory>
        </step>
        <step number="2">
          <action>Verify build success</action>
          <success_indicators>
            <indicator>BUILD SUCCESSFUL message</indicator>
            <indicator>JAR file created in build/libs/</indicator>
          </success_indicators>
        </step>
      </steps>
      <output>
        <jar_location>sdk-gen/subprojects/jdbc_{database}/build/libs/jdbc_{database}.jar</jar_location>
      </output>
    </phase>

    <phase number="10" name="flight_app_generation">
      <title>Generate Flight App</title>
      <description>
        Automatically generate a Flight app project that includes the newly created connector.
        This creates a deployable application with the connector integrated.
      </description>
      <steps>
        <step number="1">
          <action>Run autoGenerateFlightApp task</action>
          <command>./gradlew autoGenerateFlightApp -PdslFile=subprojects/jdbc_{database}/src/dist/resources/payload/etc/DSL-jdbc-{database}.json</command>
          <working_directory>sdk-gen/</working_directory>
          <note>This task automatically determines the connector name from the DSL file</note>
        </step>
        <step number="2">
          <action>Verify flight app generation</action>
          <success_indicators>
            <indicator>✅ Flight app created successfully! message</indicator>
            <indicator>Flight app directory created at subprojects/flight/</indicator>
            <indicator>Connector dependency added to flight app build.gradle</indicator>
          </success_indicators>
        </step>
        <step number="3">
          <action>Verify flight app can be built</action>
          <command>./gradlew :wdp-connect-sdk-gen-flight:build -x test</command>
          <working_directory>sdk-gen/</working_directory>
          <optional>true</optional>
          <note>This step is optional but recommended to verify the flight app is properly configured</note>
        </step>
      </steps>
      <what_it_does>
        <action>Creates flight app at sdk-gen/subprojects/flight/</action>
        <action>Adds connector as runtimeOnly dependency</action>
        <action>Configures flight app for deployment</action>
        <action>Makes connector ready for Cloud Pak for Data integration</action>
      </what_it_does>
      <output>
        <location>sdk-gen/subprojects/flight/</location>
        <gradle_project>:wdp-connect-sdk-gen-flight</gradle_project>
        <connector_dependency>runtimeOnly project(path: ':wdp-connect-sdk-gen-jdbc_{database}')</connector_dependency>
      </output>
    </phase>
  </workflow_phases>

  <completion_criteria>
    <criterion>DSL configuration file created and validated</criterion>
    <criterion>Connector code generated successfully</criterion>
    <criterion>DSL moved to connector resources directory</criterion>
    <criterion>Connector customization completed</criterion>
    <criterion>Test suite generated</criterion>
    <criterion>Code formatted with spotlessApply</criterion>
    <criterion>Connector builds successfully</criterion>
    <criterion>Flight app generated with connector integrated</criterion>
  </completion_criteria>

  <next_steps_for_user>
    <step>Review generated connector code in subprojects/jdbc_{database}/</step>
    <step>Review generated flight app in subprojects/flight/</step>
