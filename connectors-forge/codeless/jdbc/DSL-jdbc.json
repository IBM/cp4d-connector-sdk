{
    "_comment": "JDBC Connector Template - Fill in database-specific details",
    "_instructions": "This template defines the minimal configuration needed to customize a JDBC connector generated by ./gradlew generateJavaJdbc. Only modify the properties that are specific to your target database.",
    
    "connector_metadata": {
        "connector_name": "<connector_name>",
        "_example_connector_name": "jdbc_mysql, jdbc_postgres, jdbc_oracle",
        "connector_label": "<Connector Display Label>",
        "_example_connector_label": "MySQL, PostgreSQL, Oracle Database",
        "connector_description": "<Brief description of the connector>",
        "_example_connector_description": "JDBC connector for MySQL databases"
    },
    
    "jdbc_driver": {
        "jdbc_url": "<jdbc_url>",
        "driver_class_name": "<fully.qualified.DriverClassName>",
        "_example_driver_class_name": "com.mysql.cj.jdbc.Driver, org.postgresql.Driver, oracle.jdbc.OracleDriver, com.ibm.db2.jcc.DB2Driver",
        "_note": "This is the JDBC driver class that will be loaded to connect to your database"
    },
    
    "connection_properties": {
        "_note": "Define database-specific connection properties. Common properties like host, port, database, username, password are already in the template.",
        "additional_properties": [
            {
                "_example": "For SSL/TLS connections",
                "name": "ssl",
                "label": "Use SSL",
                "description": "Enable SSL/TLS encrypted connection",
                "type": "boolean",
                "required": false,
                "default_value": "false"
            },
            {
                "_example": "For connection timeout",
                "name": "connection_timeout",
                "label": "Connection Timeout",
                "description": "Connection timeout in seconds",
                "type": "integer",
                "required": false,
                "default_value": "30"
            },
            {
                "_example": "For custom JDBC URL parameters",
                "name": "jdbc_url_params",
                "label": "JDBC URL Parameters",
                "description": "Additional JDBC URL parameters (e.g., useSSL=true&serverTimezone=UTC)",
                "type": "string",
                "required": false
            }
        ]
    },
    
    "authentication": {
        "_note": "Define authentication methods supported by your database",
        "methods": [
            {
                "type": "basic",
                "_description": "Standard username/password authentication (already in template)",
                "enabled": true
            },
            {
                "type": "kerberos",
                "_description": "Kerberos authentication",
                "enabled": false,
                "properties": [
                    {
                        "name": "kerberos_principal",
                        "label": "Kerberos Principal",
                        "type": "string",
                        "required": true
                    },
                    {
                        "name": "kerberos_keytab",
                        "label": "Kerberos Keytab",
                        "type": "string",
                        "required": true,
                        "masked": true
                    }
                ]
            },
            {
                "type": "oauth",
                "_description": "OAuth 2.0 authentication",
                "enabled": false,
                "properties": [
                    {
                        "name": "oauth_token",
                        "label": "OAuth Token",
                        "type": "string",
                        "required": true,
                        "masked": true
                    }
                ]
            }
        ]
    },
    
    "database_specific_features": {
        "_note": "Define features specific to your database that differ from standard JDBC",
        "supports_schemas": true,
        "_example_supports_schemas": "true for PostgreSQL/Oracle, false for MySQL (uses catalogs)",
        "supports_catalogs": false,
        "_example_supports_catalogs": "true for MySQL, false for PostgreSQL",
        "default_schema": null,
        "_example_default_schema": "public for PostgreSQL, dbo for SQL Server",
        "system_schemas": [],
        "_example_system_schemas": "['information_schema', 'pg_catalog'] for PostgreSQL, ['sys', 'mysql'] for MySQL",
        "identifier_quote_char": "\"",
        "_example_identifier_quote_char": "\" for PostgreSQL, ` for MySQL, \" for Oracle"
    },
    
    "data_type_mappings": {
        "_note": "Define custom data type mappings if your database uses non-standard types",
        "custom_mappings": [
            {
                "_example": "PostgreSQL UUID type",
                "jdbc_type": "OTHER",
                "database_type": "uuid",
                "arrow_type": "utf8"
            },
            {
                "_example": "MySQL TINYINT as boolean",
                "jdbc_type": "TINYINT",
                "database_type": "tinyint",
                "arrow_type": "bool",
                "condition": "precision == 1"
            }
        ]
    },
    
    "url_template": {
        "_note": "JDBC URL template for your database. Use {placeholders} for connection properties",
        "template": "jdbc:<vendor>://{host}:{port}/{database}",
        "_examples": {
            "mysql": "jdbc:mysql://{host}:{port}/{database}",
            "postgresql": "jdbc:postgresql://{host}:{port}/{database}",
            "oracle": "jdbc:oracle:thin:@{host}:{port}:{database}",
            "db2": "jdbc:db2://{host}:{port}/{database}",
            "sqlserver": "jdbc:sqlserver://{host}:{port};databaseName={database}"
        }
    },
    
    "validation_rules": {
        "_note": "Define custom validation rules for connection properties",
        "rules": [
            {
                "property": "port",
                "rule": "range",
                "min": 1,
                "max": 65535
            },
            {
                "property": "database",
                "rule": "pattern",
                "pattern": "^[a-zA-Z0-9_]+$",
                "error_message": "Database name must contain only alphanumeric characters and underscores"
            }
        ]
    },
    
    "custom_actions": {
        "_note": "Define database-specific custom actions beyond the standard get_record_count",
        "actions": [
            {
                "_example": "Get table size in bytes",
                "name": "get_table_size",
                "description": "Get the physical size of a table",
                "input_properties": [
                    {
                        "name": "schema_name",
                        "type": "string",
                        "required": false
                    },
                    {
                        "name": "table_name",
                        "type": "string",
                        "required": true
                    }
                ],
                "output_properties": [
                    {
                        "name": "size_bytes",
                        "type": "integer",
                        "required": true
                    }
                ]
            }
        ]
    },
    
    "implementation_notes": {
        "_note": "Additional notes for implementing the connector",
        "files_to_modify": [
            "src/main/java/.../Connector.java - Update DRIVER_CLASS_NAME constant",
            "src/main/java/.../DatasourceType.java - Add custom connection properties",
            "src/main/java/.../Connector.java - Implement custom validation logic",
            "src/main/java/.../SourceInteraction.java - Add custom data type handling if needed",
            "src/main/java/.../Labels.properties - Update labels for custom properties"
        ],
        "dependencies": [
            {
                "_note": "JDBC driver dependencies - Uncomment and use the one for your database",
                "_format": "group:artifact:version",
                "_examples": {
                    "mysql": "com.mysql:mysql-connector-j:8.0.33",
                    "postgresql": "org.postgresql:postgresql:42.6.0",
                    "oracle": "com.oracle.database.jdbc:ojdbc8:21.9.0.0",
                    "sqlserver": "com.microsoft.sqlserver:mssql-jdbc:12.2.0.jre11",
                    "db2": "com.ibm.db2:jcc:11.5.8.0",
                    "mariadb": "org.mariadb.jdbc:mariadb-java-client:3.1.4"
                },
                "driver_dependencies": []
            }
        ]
    }
}